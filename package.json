    "url": "https://github.com/LeeGordon83/AILift/issues"
  },
  "homepage": "https://github.com/LeeGordon83/AILift#readme",
  "dependencies": {
    "@hapi/hapi": "^21.4.6",
    "@hapi/inert": "^7.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^28.1.0",
    "vitest": "^4.0.18"
  }
